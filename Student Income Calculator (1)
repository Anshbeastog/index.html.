.s1 { background: var(--color-primary); }

.s2 { background: var(--color-blue); }

.s3 { background: var(--color-success); }

.s4 { background: var(--color-warning); }

.table { display: grid; gap: var(--space-3); }

.line { display: flex; justify-content: space-between; gap: var(--space-3); padding: var(--space-3) 0; border-bottom: 1px solid var(--color-divider); }

.line:last-child { border-bottom: 0px; }

.money { font-variant-numeric: tabular-nums; font-weight: 700; }

.badge { display: inline-block; padding: var(--space-2) var(--space-3); border-radius: var(--radius-full); font-size: var(--text-xs); font-weight: 700; }

.ok { background: color-mix(in oklab,var(--color-success) 18%, transparent); color: var(--color-success); }

.warn { background: color-mix(in oklab,var(--color-warning) 18%, transparent); color: var(--color-warning); }

.notes { display: grid; gap: var(--space-3); }

.note { padding: var(--space-4); border-radius: var(--radius-lg); background: var(--color-surface-2); border: 1px solid color-mix(in oklab,var(--color-text) 10%, transparent); }

.actions { display: flex; flex-wrap: wrap; gap: var(--space-3); margin-top: var(--space-4); }

.btn { min-height: 44px; padding: 0 var(--space-4); border-radius: var(--radius-full); display: inline-flex; align-items: center; justify-content: center; font-weight: 700; border: 1px solid transparent; transition: 0.18s; }

.btn.primary { background: var(--color-primary); color: var(--color-text-inverse); }

.btn.primary:hover { background: var(--color-primary-hover); }

.btn.ghost { background: transparent; border-color: color-mix(in oklab,var(--color-text) 14%, transparent); color: var(--color-text); }

.foot { padding: var(--space-6); font-size: var(--text-sm); color: var(--color-text-muted); }

@media (max-width: 900px) {
  .hero, .grid { grid-template-columns: 1fr; }
  .stats { grid-template-columns: 1fr; }
  .intro, .controls, .card { padding: var(--space-5); }
}
